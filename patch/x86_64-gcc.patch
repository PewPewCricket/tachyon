diff -Naur gcc-15.3.0/gcc/config.gcc gcc-new/gcc/config.gcc
--- gcc-15.3.0/gcc/config.gcc	2026-06-12 01:09:06.107518032 -0500
+++ gcc-new/gcc/config.gcc	2026-06-25 20:27:58.119768190 -0500
@@ -1960,6 +1960,7 @@
 	tm_file="${tm_file} i386/unix.h i386/att.h elfos.h newlib-stdint.h i386/i386elf.h"
 	;;
