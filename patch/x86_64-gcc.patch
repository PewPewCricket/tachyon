diff -Naur gcc-15.3.0/gcc/config/i386/t-x86_64-elf gcc-new/gcc/config/i386/t-x86_64-elf
--- gcc-15.3.0/gcc/config/i386/t-x86_64-elf	1969-12-31 18:00:00.000000000 -0600
+++ gcc-new/gcc/config/i386/t-x86_64-elf	2026-06-25 20:25:41.205014190 -0500
@@ -0,0 +1,4 @@
+# Add libgcc multilib variant without red-zone requirement
+
+MULTILIB_OPTIONS += mno-red-zone
